{
  "name": "atomquest-goal-portal",
  "version": "1.0.0",
  "description": "AtomQuest Hackathon 1.0 — In-House Goal Setting & Tracking Portal",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "test": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:all": "concurrently \"npm run test --workspace=server\" \"npm run test --workspace=client\"",
    "lint": "eslint \"server/src/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "format": "prettier --write \"server/src/**/*.js\" \"client/src/**/*.{js,jsx}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "react-icons": "^5.6.0"
  }
}
